# ── Movie Recap Studio – Environment Variables ─────────────────────────────
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# These are only needed for production builds (Vercel, etc.).
# During local development, default values work out of the box.

# ── TTS (Text-to-Speech) Backend ──────────────────────────────────────────
#
# URL of the deployed Edge TTS server (Node.js Express server).
# In development, Vite proxies /api/tts requests to localhost:3001.
# When deploying to Vercel (frontend only), deploy the TTS server separately
# and point this env var to its public URL.
#
# Example: https://your-tts-server.vercel.app
# VITE_TTS_API_BASE=

# ── API Keys (optional – user enters these in the app UI) ─────────────────
# The app stores API keys (OpenAI, Google, etc.) in the browser's localStorage.
# No env vars are needed for API keys.
